---
import { getPublishStatus } from '../utils/publishDate';

interface Props {
  pubDate: Date;
}

const { pubDate } = Astro.props;
const status = getPublishStatus(pubDate);

// Don't render if published
if (!status) return null;
---

<div class="unpublished-warning" role="alert">
  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
    <circle cx="12" cy="12" r="10"></circle>
    <line x1="12" y1="8" x2="12" y2="12"></line>
    <line x1="12" y1="16" x2="12.01" y2="16"></line>
  </svg>
  <div class="warning-content">
    <strong>This article is not yet published</strong>
    <p>{status}. This page is accessible but won't appear in post listings until the publication date.</p>
  </div>
</div>

<style>
  .unpublished-warning {
    background: linear-gradient(135deg, #fff3cd 0%, #ffeaa7 100%);
    border-left: 4px solid #f39c12;
    border-radius: 8px;
    padding: 1.25rem 1.5rem;
    margin: 2rem 0;
    display: flex;
    gap: 1rem;
    align-items: flex-start;
    box-shadow: 0 2px 8px rgba(243, 156, 18, 0.1);
    animation: slideIn 0.3s ease-out;
  }

  @keyframes slideIn {
    from {
      opacity: 0;
      transform: translateY(-10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .unpublished-warning svg {
    flex-shrink: 0;
    color: #e67e22;
    margin-top: 0.125rem;
  }

  .warning-content {
    flex: 1;
  }

  .warning-content strong {
    display: block;
    color: #e67e22;
    font-size: 1rem;
    margin-bottom: 0.375rem;
    font-weight: 600;
  }

  .warning-content p {
    color: #7d5e2b;
    font-size: 0.9375rem;
    line-height: 1.5;
    margin: 0;
  }

  @media (max-width: 768px) {
    .unpublished-warning {
      padding: 1rem;
      gap: 0.75rem;
    }

    .warning-content strong {
      font-size: 0.9375rem;
    }

    .warning-content p {
      font-size: 0.875rem;
    }
  }

  @media (prefers-color-scheme: dark) {
    .unpublished-warning {
      background: linear-gradient(135deg, #3d3520 0%, #4a3f1f 100%);
      border-left-color: #f39c12;
    }

    .warning-content strong {
      color: #f39c12;
    }

    .warning-content p {
      color: #d4b886;
    }
  }
</style>
