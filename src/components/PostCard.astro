---
import type { ProcessedPost } from '../utils/dataCache';
import { isArticleNew } from '../utils/newArticles';

interface Props { 
  post: ProcessedPost;
  collection?: 'posts' | 'ainews' | 'aifinnews';
}

const { post, collection } = Astro.props;

// Use precomputed URL from ProcessedPost
const url = post.urlPath;

// Format date consistently (ISO 8601 format)
const date = post.data.pubDate.toISOString().split('T')[0];

// Use precomputed excerpt from ProcessedPost
const excerpt = post.excerpt;

// Precompute lowercase categories for efficient comparison
const lowerCategories = post.data.categories?.map((c: string) => c.toLowerCase()) || [];

// Check if post has AI News tag
const hasAINewsTag = lowerCategories.includes('ai news');

// Check if post has Stock Weather AI tag
const hasStockWeatherTag = lowerCategories.includes('stock weather ai');

// Check if article is new (modified in last x hours)
const isNew = collection ? isArticleNew(post.slug, collection) : false;
---

<article class="post-card" data-article-url={url}>
  <!-- Read status indicator / New badge -->
  <div class="read-indicator" aria-hidden="true">
    <svg 
      width="18" 
      height="18" 
      viewBox="0 0 24 24" 
      fill="none" 
      stroke="currentColor" 
      stroke-width="3" 
      stroke-linecap="round" 
      stroke-linejoin="round"
    >
      <polyline points="20 6 9 17 4 12"></polyline>
    </svg>
    
    <!-- Clear button (appears on hover) -->
    <button 
      class="clear-read-btn" 
      title="Clear from read list" 
      aria-label="Remove this article from read list"
      data-article-url={url}
    >
      <svg 
        width="14" 
        height="14" 
        viewBox="0 0 24 24" 
        fill="none" 
        stroke="currentColor" 
        stroke-width="2.5" 
        stroke-linecap="round" 
        stroke-linejoin="round"
      >
        <line x1="18" y1="6" x2="6" y2="18"></line>
        <line x1="6" y1="6" x2="18" y2="18"></line>
      </svg>
    </button>
  </div>

  <!-- New article badge (shown when not read) -->
  {isNew && (
    <div class="new-indicator" aria-label="New article">
      <span class="new-badge-card">NEW</span>
    </div>
  )}

  <!-- Post metadata -->
  <div class="meta-row">
    <time datetime={post.data.pubDate.toISOString()}>
      {date}
    </time>
    <span>{post.readingTime.text}</span>
  </div>

  <!-- Post title -->
  <h3>
    <a href={url} class="card-link">
      {post.data.title}
    </a>
  </h3>

  <!-- Categories/Tags -->
  {post.data.categories && (
    <div class="tag-row">
      {post.data.categories
        .filter((category: string, idx: number) => lowerCategories[idx] !== 'ai assisted')
        .map((category: string, idx: number) => {
        const categoryLower = category.toLowerCase();
        const isAINews = categoryLower === 'ai news';
        const isStockWeatherAI = categoryLower === 'stock weather ai';
        
        // Build class list
        let tagClass = 'post-tag';
        if (isAINews) tagClass += ' ai-news-tag ai-gradient-tag';
        if (isStockWeatherAI) tagClass += ' stock-weather-ai-tag ai-gradient-tag';
        
        // AI News posts: make AI News tag clickable, others static
        if (collection === 'ainews' && isAINews) {
          return (
            <a class={tagClass} href="/ai-news/">
              {category}
            </a>
          );
        }
        
        // AI Financial News posts: make Stock Weather AI tag clickable, others static
        if (collection === 'aifinnews' && isStockWeatherAI) {
          return (
            <a class={tagClass} href="/ai-financial-news/">
              {category}
            </a>
          );
        }
        
        return <span class={tagClass}>{category}</span>;
      })}
    </div>
  )}

  <!-- Stretched link for entire card clickability -->
  <a 
    class="stretched-link" 
    href={url} 
    aria-label={`Read article: ${post.data.title}`}
  >
  </a>

  <!-- Post excerpt -->
  <p class="excerpt">{excerpt}</p>
</article>