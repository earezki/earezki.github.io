---
import '../styles/_search.css';
import { SITE } from '../config/site';
---

<div class="header-search" data-search-api-url={SITE.searchAPI.url} data-search-timeout={SITE.searchAPI.timeout}>
  <div class="search-box" id="search-box">
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="search-icon" aria-hidden="true">
      <circle cx="11" cy="11" r="8"></circle>
      <path d="m21 21-4.35-4.35"></path>
    </svg>
    <input type="text" id="search-input" placeholder="Search ..." class="search-input" autocomplete="off" aria-label="Search articles" minlength="3" />
    <button id="clear-search" class="clear-button" style="display: none;" aria-label="Clear search">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="18" y1="6" x2="6" y2="18"></line>
        <line x1="6" y1="6" x2="18" y2="18"></line>
      </svg>
    </button>
  </div>
  <div id="search-results" class="search-results" role="status" aria-live="polite"></div>
</div>
<script>
  let searchIndex: any[] | null = null;
  let isLoadingIndex = false;
  
  const DB_NAME = 'earezki-search-db';
  const DB_VERSION = 1;
  const STORE_NAME = 'search-index';
  const INDEX_KEY = 'search-data';
  const VERSION_KEY = 'index-version';
  
  const headerElement = document.querySelector('.header-search') as HTMLElement;
  const SERVER_API_URL = headerElement?.dataset.searchApiUrl || '';
  const SERVER_TIMEOUT = parseInt(headerElement?.dataset.searchTimeout || '2000', 10);
  
  const queryCache = new Map<string, { results: any[], isAPI: boolean }>();
  const MAX_CACHE_SIZE = 10;
  
  function initDB(): Promise<IDBDatabase> {
    return new Promise((resolve, reject) => {
      const req = indexedDB.open(DB_NAME, DB_VERSION);
      req.onerror = () => reject(req.error);
      req.onsuccess = () => resolve(req.result);
      req.onupgradeneeded = (e) => {
        const db = (e.target as IDBOpenDBRequest).result;
        if (!db.objectStoreNames.contains(STORE_NAME)) {
          db.createObjectStore(STORE_NAME);
        }
      };
    });
  }

  async function getCachedIndex(): Promise<{ data: any[] | null; version: string | null }> {
    try {
      const db = await initDB();
      const tx = db.transaction(STORE_NAME, 'readonly');
      const store = tx.objectStore(STORE_NAME);

      return new Promise((resolve) => {
        const dataReq = store.get(INDEX_KEY);
        const versionReq = store.get(VERSION_KEY);
        let completed = 0, data: any[] | null = null, version: string | null = null;

        dataReq.onsuccess = () => {
          data = dataReq.result || null;
          if (++completed === 2) resolve({ data, version });
        };
        versionReq.onsuccess = () => {
          version = versionReq.result || null;
          if (++completed === 2) resolve({ data, version });
        };
        dataReq.onerror = versionReq.onerror = () => resolve({ data: null, version: null });
      });
    } catch (error) {
      console.warn('[Search] IndexedDB failed:', error);
      return { data: null, version: null };
    }
  }

  async function cacheIndex(data: any[], version: string): Promise<void> {
    try {
      const db = await initDB();
      const tx = db.transaction(STORE_NAME, 'readwrite');
      const store = tx.objectStore(STORE_NAME);
      store.put(data, INDEX_KEY);
      store.put(version, VERSION_KEY);
      return new Promise((resolve, reject) => {
        tx.oncomplete = () => resolve();
        tx.onerror = () => reject(tx.error);
      });
    } catch (error) {
      console.warn('[Search] Cache failed:', error);
    }
  }

  async function getRemoteVersion(): Promise<string | null> {
    try {
      const res = await fetch('/search.json', { method: 'HEAD' });
      return res.headers.get('ETag') || res.headers.get('Last-Modified');
    } catch (error) {
      console.warn('[Search] Version check failed:', error);
      return null;
    }
  }

  async function loadSearchIndex(): Promise<any[]> {
    if (searchIndex) return searchIndex;
    if (isLoadingIndex) {
      await new Promise(r => setTimeout(r, 100));
      return loadSearchIndex();
    }
    isLoadingIndex = true;

    try {
      const remoteVer = await getRemoteVersion();
      const { data: cached, version: cachedVer } = await getCachedIndex();

      if (cached && cachedVer && remoteVer && cachedVer === remoteVer) {
        searchIndex = cached;
        return cached;
      }

      console.log('[Search] Fetching index');
      const res = await fetch('/search.json');
      if (!res.ok) {
        if (cached) {
          console.warn('[Search] Fetch failed, using stale cache');
          searchIndex = cached;
          return cached;
        }
        throw new Error(`Fetch failed: ${res.status}`);
      }

      const data = await res.json();
      searchIndex = data;
      if (remoteVer) await cacheIndex(data, remoteVer);
      return data;
    } catch (error) {
      console.error('[Search] Load failed:', error);
      const { data: cached } = await getCachedIndex();
      if (cached) {
        searchIndex = cached;
        return cached;
      }
      return [];
    } finally {
      isLoadingIndex = false;
    }
  }
  
  function cleanText(text: string): string {
    return text.replace(/^["']|["']$/g, '').replace(/\\"/g, '"').replace(/\\'/g, "'");
  }

  function ensureTrailingSlash(url: string): string {
    return url.endsWith('/') ? url : url + '/';
  }

  async function queryServerAPI(query: string): Promise<any[] | null> {
    if (!SERVER_API_URL) {
      return null;
    }
    
    try {
      const controller = new AbortController();
      const timeoutId = setTimeout(() => controller.abort(), SERVER_TIMEOUT);
      
      const response = await fetch(`${SERVER_API_URL}?k=${encodeURIComponent(query)}`, {
        signal: controller.signal,
        headers: {
          'Accept': 'application/json'
        }
      });
      
      clearTimeout(timeoutId);
      
      if (!response.ok) {
        console.warn('[Search] Server API returned error:', response.status);
        return null;
      }
      
      const results = await response.json();
      
      // Transform server results to match client-side format
      return results.map((item: any) => {
        const url = ensureTrailingSlash(item.url);
        return {
          title: cleanText(item.title),
          excerpt: cleanText(item.description),
          pubDate: item.published_at,
          url: url,
          categories: []
        };
      });
    } catch (error) {
      if (error instanceof Error && error.name === 'AbortError') {
        console.warn('[Search] Server API timeout, falling back to client search');
      } else {
        console.warn('[Search] Server API error, falling back to client search:', error);
      }
      return null;
    }
  }
  
  const readCache = new Map<string, boolean>();
  
  function isArticleRead(url: string): boolean {
    if (readCache.has(url)) return readCache.get(url)!;
    try {
      const read = JSON.parse(localStorage.getItem('readArticles') || '[]');
      const isRead = read.includes(url);
      readCache.set(url, isRead);
      return isRead;
    } catch {
      return false;
    }
  }
  
  document.addEventListener('DOMContentLoaded', async function() {
    const box = document.getElementById('search-box') as HTMLElement;
    const input = document.getElementById('search-input') as HTMLInputElement;
    const clear = document.getElementById('clear-search') as HTMLButtonElement;
    const results = document.getElementById('search-results') as HTMLElement;
    const header = document.querySelector('.header-search') as HTMLElement;
    const siteHdr = document.querySelector('.site-header') as HTMLElement;
    
    if (!input || !results || !box) return;
    
    await loadSearchIndex();
    
    let lastQ = '', lastHash = '';
    
    input.addEventListener('focus', function() {
      box.classList.add('vibrating');
      setTimeout(() => box.classList.remove('vibrating'), 200);
      
      if (siteHdr) siteHdr.classList.add('search-active');
      if (header) header.classList.add('search-active');
      
      if (input.value.trim().length >= 3) performSearch(input.value);
    });
    
    input.addEventListener('blur', function() {
      setTimeout(() => {
        if (siteHdr) siteHdr.classList.remove('search-active');
        if (header) header.classList.remove('search-active');
      }, 100);
    });
    
    async function performSearch(q: string) {
      q = q.trim();
      
      if (!q || q.length < 3) {
        results.style.display = 'none';
        if (clear) clear.style.display = q.length > 0 ? 'flex' : 'none';
        lastQ = lastHash = '';
        return;
      }
      
      if (q === lastQ && results.style.display === 'block') return;
      lastQ = q;
      if (clear) clear.style.display = 'flex';
      
      if (queryCache.has(q)) {
        const cached = queryCache.get(q)!;
        displayResults(cached.results, cached.isAPI);
        return;
      }
      
      let searchResults: any[] | null = await queryServerAPI(q);
      let isAPISearch = !!searchResults;
      
      if (!searchResults) {
        const idx = await loadSearchIndex();
        const qLower = q.toLowerCase();
        const keywords = qLower.split(/\s+/).filter(k => k.length >= 2);
        
        const scored = idx.map((art: any) => {
          const title = art.title.toLowerCase();
          const excerpt = art.excerpt.toLowerCase();
          const cats = art.categories.map((c: string) => c.toLowerCase()).join(' ');
          
          let score = 0, matched = 0;
          for (const kw of keywords) {
            if (title.includes(kw)) { score += 10; matched++; }
            if (cats.includes(kw)) { score += 5; matched++; }
            if (excerpt.includes(kw)) { score += 2; matched++; }
          }
          
          return matched >= keywords.length ? { art, score } : null;
        }).filter(Boolean) as Array<{ art: any; score: number }>;
        
        searchResults = scored.sort((a, b) => b.score - a.score).map(i => i.art);
        isAPISearch = false;
      }
      
      if (queryCache.size >= MAX_CACHE_SIZE) {
        const firstKey = queryCache.keys().next().value;
        if (firstKey) queryCache.delete(firstKey);
      }
      queryCache.set(q, { results: searchResults, isAPI: isAPISearch });
      
      const hash = searchResults.slice(0, 6).map(a => a.url).join('|');
      if (hash !== lastHash || results.style.display !== 'block') {
        lastHash = hash;
        displayResults(searchResults, isAPISearch);
      }
    }
    
    function displayResults(arts: any[], isAPISearch: boolean = false) {
      results.innerHTML = '';
      
      const scrollWrapper = document.createElement('div');
      scrollWrapper.className = 'search-results-scroll';
      
      if (arts.length === 0) {
        const noResults = document.createElement('div');
        noResults.className = 'search-no-results';
        noResults.innerHTML = `
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
          <div>No results found. Try different keywords.</div>
        `;
        scrollWrapper.appendChild(noResults);
        results.appendChild(scrollWrapper);
        results.style.display = 'flex';
        return;
      }
      
      const total = arts.length;
      const shown = arts.slice(0, 6);
      
      shown.forEach(function(art) {
        const date = new Date(art.pubDate).toLocaleDateString('en-US', { 
          year: 'numeric', month: 'short', day: 'numeric' 
        });
        const words = (art.excerpt || '').split(' ');
        const excerpt = words.slice(0, 10).join(' ') + (words.length > 10 ? '...' : '');
        const isRead = isArticleRead(art.url);
        
        const card = document.createElement('a');
        card.href = art.url;
        card.className = 'search-result-card';
        
        const content = document.createElement('div');
        content.className = 'search-result-content';
        
        const dateEl = document.createElement('div');
        dateEl.className = 'search-result-date';
        dateEl.textContent = date;
        
        const titleEl = document.createElement('h3');
        titleEl.className = 'search-result-title';
        titleEl.textContent = art.title;
        
        const excerptEl = document.createElement('p');
        excerptEl.className = 'search-result-excerpt';
        excerptEl.textContent = excerpt;
        
        content.appendChild(dateEl);
        content.appendChild(titleEl);
        content.appendChild(excerptEl);
        
        const actions = document.createElement('div');
        actions.className = 'search-result-actions';
        
        if (isRead) {
          const readIcon = document.createElement('div');
          readIcon.className = 'search-result-icon read-indicator';
          readIcon.title = 'Already read';
          readIcon.innerHTML = `
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="20 6 9 17 4 12"></polyline>
            </svg>
          `;
          actions.appendChild(readIcon);
        }
        
        const goIcon = document.createElement('div');
        goIcon.className = 'search-result-icon go-icon';
        goIcon.title = 'Read article';
        goIcon.innerHTML = `
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="9 18 15 12 9 6"></polyline>
          </svg>
        `;
        actions.appendChild(goIcon);
        
        card.appendChild(content);
        card.appendChild(actions);
        scrollWrapper.appendChild(card);
      });
      
      if (total > 6) {
        const more = document.createElement('div');
        more.className = 'search-more-results';
        const rem = total - 6;
        more.innerHTML = `<strong>+${rem}</strong> more result${rem !== 1 ? 's' : ''} not shown`;
        scrollWrapper.appendChild(more);
      }
      
        results.appendChild(scrollWrapper);
      
      if (isAPISearch) {
        const footer = document.createElement('div');
        footer.className = 'search-footer';
        footer.innerHTML = '<small>✨ Powered by AI Search</small>';
        results.appendChild(footer);
      }      results.style.display = 'flex';
    }
    
    let timeout: number;
    input.addEventListener('input', function(e) {
      clearTimeout(timeout);
      timeout = window.setTimeout(() => {
        performSearch((e.target as HTMLInputElement).value);
      }, 500);
    });
    
    if (clear) {
      clear.addEventListener('click', function() {
        input.value = '';
        results.style.display = 'none';
        clear.style.display = 'none';
        if (siteHdr) siteHdr.classList.remove('search-active');
        if (header) header.classList.remove('search-active');
        input.focus();
      });
    }
    
    document.addEventListener('click', function(e) {
      if (header && !header.contains(e.target as Node)) {
        results.style.display = 'none';
        if (siteHdr) siteHdr.classList.remove('search-active');
        if (header) header.classList.remove('search-active');
      }
    });
  });
</script>
