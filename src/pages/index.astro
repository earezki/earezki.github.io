---
import BaseLayout from "../layouts/BaseLayout.astro";
import PostCard from '../components/PostCard.astro';
import { SITE } from '../config/site';
import { getPaginatedPosts } from '../utils/dataCache';

// Fetch first page of posts using cached data
const pagination = await getPaginatedPosts(1, SITE.postsPerPage);
const { posts, totalPages } = pagination;

// Structured data for SEO (JSON-LD)
const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Dev|Journal',
  url: 'https://earezki.com/',
  author: {
    '@type': 'Person',
    name: 'El Mehdi Arezki',
    url: 'https://earezki.com/about',
    jobTitle: 'Lead Software Engineer',
    sameAs: [
      'https://github.com/earezki',
      'https://www.linkedin.com/in/mehdi-arezki'
    ]
  },
  description: 'Technical blog covering software architecture, backend development, and engineering best practices'
};
---

<BaseLayout 
  title="Dev|Journal - Software Architecture, Backend Development & Technical Insights" 
  description="Technical blog by El Mehdi Arezki - Lead Software Engineer. In-depth articles on software architecture, microservices, domain-driven design, Java, Python, and cloud-native development."
  keywords="software architecture, backend development, microservices, domain-driven design, DDD, Java, Python, Spring Boot, Kubernetes, cloud native, technical blog"
  author="El Mehdi Arezki"
  canonical="/" 
  image="/assets/og-image-default.jpg"
  structuredData={structuredData}
>
  <!-- Screen reader only heading for accessibility -->
  <h1 class="sr-only">
    Dev|Journal - Software Architecture & Backend Development Blog
  </h1>
  
  <!-- Featured Topics Section -->
  <section class="featured-topics fade-in-up" aria-label="Featured topics">
    <h2>Explore Topics</h2>
    <div class="topic-cards-scroll">
      <div class="topic-cards">
        <a href="/tags/solid/" class="topic-card">
          <span class="topic-icon">🎯</span>
          <h3>SOLID Principles</h3>
          <p>Learn object-oriented design principles for better code</p>
        </a>
        <a href="/tags/software-architecture/" class="topic-card">
          <span class="topic-icon">🏗️</span>
          <h3>Software Architecture</h3>
          <p>Patterns and practices for scalable systems</p>
        </a>
        <a href="/tags/domain-driven-design/" class="topic-card">
          <span class="topic-icon">📐</span>
          <h3>Domain-Driven Design</h3>
          <p>Build software that reflects your business domain</p>
        </a>
        <a href="/tags/algorithms/" class="topic-card">
          <span class="topic-icon">🔀</span>
          <h3>Algorithms</h3>
          <p>Master core algorithm patterns and data structures</p>
        </a>
        <a href="/ai-news/" class="topic-card ai-topic">
          <span class="topic-icon">🤖</span>
          <h3>AI News</h3>
          <p>Latest developments in artificial intelligence</p>
        </a>
        <!-- Duplicated for continuous scroll -->
        <a href="/tags/solid/" class="topic-card">
          <span class="topic-icon">🎯</span>
          <h3>SOLID Principles</h3>
          <p>Learn object-oriented design principles for better code</p>
        </a>
        <a href="/tags/software-architecture/" class="topic-card">
          <span class="topic-icon">🏗️</span>
          <h3>Software Architecture</h3>
          <p>Patterns and practices for scalable systems</p>
        </a>
        <a href="/tags/domain-driven-design/" class="topic-card">
          <span class="topic-icon">📐</span>
          <h3>Domain-Driven Design</h3>
          <p>Build software that reflects your business domain</p>
        </a>
        <a href="/tags/algorithms/" class="topic-card">
          <span class="topic-icon">🔀</span>
          <h3>Algorithms</h3>
          <p>Master core algorithm patterns and data structures</p>
        </a>
        <a href="/ai-news/" class="topic-card ai-topic">
          <span class="topic-icon">🤖</span>
          <h3>AI News</h3>
          <p>Latest developments in artificial intelligence</p>
        </a>
      </div>
    </div>
  </section>
  
  <!-- Posts grid -->
  <section class="posts-grid" aria-label="Blog posts">
    {posts.map((post) => <PostCard post={post} />)}
  </section>
  
  <!-- Pagination -->
  {totalPages > 1 && (
    <nav class="pagination" aria-label="Pagination">
      <a href="/page/2/" rel="next">
        Older →
      </a>
    </nav>
  )}
</BaseLayout>

<script>
  const topicCardsScroll = document.querySelector('.topic-cards-scroll') as HTMLElement;
  const topicCards = document.querySelector('.topic-cards') as HTMLElement;
  const allCards = document.querySelectorAll('.topic-card') as NodeListOf<HTMLElement>;
  
  if (topicCardsScroll && topicCards) {
    let isDown = false;
    let startX = 0;
    let scrollLeft = 0;
    let hasDragged = false;
    
    topicCardsScroll.addEventListener('mousedown', (e: MouseEvent) => {
      isDown = true;
      hasDragged = false;
      topicCardsScroll.style.cursor = 'grabbing';
      startX = e.pageX - topicCardsScroll.offsetLeft;
      scrollLeft = topicCardsScroll.scrollLeft;
      topicCards.style.animationPlayState = 'paused';
    });
    
    topicCardsScroll.addEventListener('mouseleave', () => {
      isDown = false;
      topicCardsScroll.style.cursor = 'grab';
      topicCards.style.animationPlayState = 'running';
      allCards.forEach(card => card.classList.remove('dragging'));
    });
    
    topicCardsScroll.addEventListener('mouseup', () => {
      isDown = false;
      topicCardsScroll.style.cursor = 'grab';
      topicCards.style.animationPlayState = 'running';
      allCards.forEach(card => card.classList.remove('dragging'));
    });
    
    topicCardsScroll.addEventListener('mousemove', (e: MouseEvent) => {
      if (!isDown) return;
      e.preventDefault();
      
      const x = e.pageX - topicCardsScroll.offsetLeft;
      const walk = (x - startX) * 2; // Multiply for faster scrolling
      
      // If moved more than 5px, mark as dragged and disable card pointer events
      if (Math.abs(walk) > 5 && !hasDragged) {
        hasDragged = true;
        allCards.forEach(card => card.classList.add('dragging'));
      }
      
      topicCardsScroll.scrollLeft = scrollLeft - walk;
    });
    
    // Prevent click navigation if we dragged
    allCards.forEach(card => {
      card.addEventListener('click', (e: MouseEvent) => {
        if (hasDragged) {
          e.preventDefault();
          e.stopPropagation();
        }
      });
    });
  }
</script>

<style>
  .featured-topics {
    margin: 0 0 3rem;
  }
  
  .featured-topics h2 {
    font-size: 1.75rem;
    margin: 0 0 1.5rem;
    color: var(--color-text);
  }
  
  .topic-cards-scroll {
    position: relative;
    overflow-x: auto;
    overflow-y: hidden;
    padding-top: 0.75rem;
    cursor: grab;
    scrollbar-width: none; /* Firefox */
    -ms-overflow-style: none; /* IE/Edge */
    mask-image: linear-gradient(90deg, 
      transparent 0%, 
      black 5%, 
      black 95%, 
      transparent 100%);
    -webkit-mask-image: linear-gradient(90deg, 
      transparent 0%, 
      black 5%, 
      black 95%, 
      transparent 100%);
  }
  
  /* Hide scrollbar for Chrome, Safari and Opera */
  .topic-cards-scroll::-webkit-scrollbar {
    display: none;
  }
  
  .topic-cards {
    display: flex;
    gap: 1.25rem;
    animation: scroll 25s linear infinite;
    will-change: transform;
    margin-bottom: 2rem;
  }
  
  @keyframes scroll {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(calc(-50% - 0.625rem));
    }
  }
  
  .topic-cards:hover {
    animation-play-state: paused;
  }
  
  .topic-card {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 1.5rem;
    background: var(--color-bg-alt);
    border: 2px solid var(--color-border);
    border-radius: var(--radius-md);
    text-decoration: none;
    transition: all 0.3s cubic-bezier(0.4, 0.0, 0.2, 1);
    position: relative;
    overflow: hidden;
    flex-shrink: 0;
    min-width: 240px;
    pointer-events: auto;
  }
  
  .topic-card.dragging {
    pointer-events: none;
  }
  
  /* Gradient background overlay for all topic cards */
  .topic-card::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, 
      rgba(99, 102, 241, 0.05) 0%,
      rgba(168, 85, 247, 0.03) 50%,
      rgba(59, 130, 246, 0.04) 100%);
    opacity: 0;
    transition: opacity 0.4s cubic-bezier(0.4, 0.0, 0.2, 1);
    border-radius: var(--radius-md);
  }
  
  html[data-theme="dark"] .topic-card::before {
    background: linear-gradient(135deg, 
      rgba(99, 102, 241, 0.08) 0%,
      rgba(168, 85, 247, 0.06) 50%,
      rgba(59, 130, 246, 0.07) 100%);
  }
  
  /* Gradient border effect */
  .topic-card::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: var(--radius-md);
    padding: 2px;
    background: linear-gradient(135deg, 
      rgba(99, 102, 241, 0.4),
      rgba(168, 85, 247, 0.4),
      rgba(59, 130, 246, 0.4));
    -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    mask-composite: exclude;
    opacity: 0;
    transition: opacity 0.4s cubic-bezier(0.4, 0.0, 0.2, 1);
  }
  
  .topic-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 12px 32px -8px rgba(99, 102, 241, 0.2),
                0 6px 20px -4px rgba(168, 85, 247, 0.15);
    border-color: rgba(99, 102, 241, 0.3);
  }
  
  html[data-theme="dark"] .topic-card:hover {
    box-shadow: 0 12px 32px -8px rgba(99, 102, 241, 0.3),
                0 6px 20px -4px rgba(168, 85, 247, 0.25);
  }
  
  .topic-card:hover::before {
    opacity: 1;
  }
  
  .topic-card:hover::after {
    opacity: 1;
  }
  
  .topic-card:active {
    transform: translateY(-4px);
  }
  
  .topic-card.ai-topic {
    background: linear-gradient(135deg, 
      rgba(102, 126, 234, 0.06), 
      rgba(118, 75, 162, 0.04));
  }
  
  html[data-theme="dark"] .topic-card.ai-topic {
    background: linear-gradient(135deg, 
      rgba(102, 126, 234, 0.12), 
      rgba(118, 75, 162, 0.08));
  }
  
  /* Enhanced AI topic card gradient */
  .topic-card.ai-topic::before {
    background: var(--ai-gradient);
    opacity: 0.08;
  }
  
  html[data-theme="dark"] .topic-card.ai-topic::before {
    opacity: 0.12;
  }
  
  .topic-card.ai-topic:hover::before {
    opacity: 0.15;
  }
  
  html[data-theme="dark"] .topic-card.ai-topic:hover::before {
    opacity: 0.2;
  }
  
  .topic-icon {
    font-size: 2rem;
    line-height: 1;
    transition: transform 0.4s cubic-bezier(0.4, 0.0, 0.2, 1);
    display: inline-block;
  }
  
  .topic-card:hover .topic-icon {
    transform: scale(1.15) rotate(5deg);
  }
  
  .topic-card h3 {
    margin: 0;
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--color-text);
  }
  
  .topic-card:hover h3 {
    color: var(--color-accent);
  }
  
  .topic-card p {
    margin: 0;
    font-size: 0.85rem;
    color: var(--color-text-alt);
    line-height: 1.4;
  }
  
  .pagination { 
    display: flex; 
    justify-content: flex-end; 
    margin: 2.5rem 0 1rem; 
    font-size: 0.9rem; 
  }
  
  .pagination a { 
    padding: 0.55rem 1rem; 
    background: var(--color-bg-alt); 
    border: 1px solid var(--color-border); 
    border-radius: var(--radius-pill);
    transition: background 0.3s cubic-bezier(0.4, 0.0, 0.2, 1), 
                color 0.3s cubic-bezier(0.4, 0.0, 0.2, 1), 
                border-color 0.3s cubic-bezier(0.4, 0.0, 0.2, 1),
                transform 0.2s cubic-bezier(0.4, 0.0, 0.2, 1),
                box-shadow 0.3s cubic-bezier(0.4, 0.0, 0.2, 1);
    position: relative;
    overflow: hidden;
  }
  
  .pagination a::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, 
      rgba(99, 102, 241, 0.1),
      rgba(168, 85, 247, 0.1));
    opacity: 0;
    transition: opacity 0.3s cubic-bezier(0.4, 0.0, 0.2, 1);
  }
  
  .pagination a:hover { 
    background: var(--color-accent); 
    color: #fff; 
    border-color: var(--color-accent); 
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(99, 102, 241, 0.3);
  }
  
  .pagination a:hover::before {
    opacity: 1;
  }
  
  .pagination a:active {
    transform: translateY(0);
  }
  
  @media (max-width: 680px) {
    .topic-cards {
      grid-template-columns: 1fr;
    }
  }
</style>
