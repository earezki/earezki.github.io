---
import BaseLayout from "../../layouts/BaseLayout.astro";
import TableOfContents from '../../components/TableOfContents.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import RelatedPosts from '../../components/RelatedPosts.astro';
import { getAllAinews, getAllProcessedContent, findAinewsBySlug } from '../../utils/dataCache';
import { RelatedPostsFinder, generateBreadcrumbs } from '../../utils/relatedContentOptimized';
import { slugify } from '../../utils/slugify';
import { isArticleNew } from '../../utils/newArticles';

export async function getStaticPaths() {
  const posts = await getAllAinews();
  return posts.map(post => ({ params: { slug: post.slug } }));
}

const { slug } = Astro.params;
const post = await findAinewsBySlug(slug!);
if (!post) throw new Error(`AI News post not found for slug: ${slug}`);

// Get raw post for rendering
const ainews = await getAllAinews();
const rawPost = ainews.find(p => p.slug === slug);
if (!rawPost) throw new Error(`Raw AI news post not found for slug: ${slug}`);

// Use precomputed metadata
const stats = post.readingTime;
const excerpt = post.excerpt;
const canonical = post.urlPath;
const postImage = `https://earezki.com/assets/og-image-default.jpg`;
const postKeywords = 'AI News, Technology';

// Precompute lowercase categories for runtime optimization
const lowerCategories = post.data.categories?.map((c: string) => c.toLowerCase()) || [];

// Check if article is new
const isNew = isArticleNew(post.slug, 'ainews');

// Generate breadcrumbs
const breadcrumbs = generateBreadcrumbs(canonical, post.data.title);

// Initialize optimized related posts finder with all content
const allContent = await getAllProcessedContent();
const relatedFinder = new RelatedPostsFinder(allContent);

// Find related content using optimized algorithm
const relatedPosts = relatedFinder.findRelated(post, 3);

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: post.data.title,
  description: excerpt,
  image: postImage,
  datePublished: post.data.pubDate.toISOString(),
  dateModified: post.data.pubDate.toISOString(),
  author: {
    '@type': 'Person',
    name: 'El Mehdi Arezki',
    url: 'https://earezki.com/about',
    jobTitle: 'Lead Software Engineer',
    sameAs: [
      'https://github.com/earezki',
      'https://www.linkedin.com/in/mehdi-arezki'
    ]
  },
  publisher: {
    '@type': 'Organization',
    name: 'Dev|Journal',
    url: 'https://earezki.com',
    logo: {
      '@type': 'ImageObject',
      url: 'https://earezki.com/assets/logo.png'
    }
  },
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': 'https://earezki.com' + canonical
  }
};
const { Content } = await rawPost.render();
---
<BaseLayout 
  title={post.data.title} 
  description={excerpt} 
  keywords={postKeywords}
  canonical={canonical} 
  image={postImage}
  structuredData={structuredData}
  isArticlePage={true}>
  <Breadcrumbs breadcrumbs={breadcrumbs} isNew={isNew} />
  <div class="post-layout">
    <aside class="sidebar-left">
      <TableOfContents markdown={post.body} />
    </aside>
    <article class="post">
      <header class="post-header">
        <h1>{post.data.title}</h1>
        <div class="meta">
          <time datetime={post.data.pubDate.toISOString()}>{post.data.pubDate.toDateString()}</time>
          <span>• {stats.text}</span>
        </div>
        {post.data.categories && <div class="tag-row">{post.data.categories.map((c: string, idx: number) => {
          const slugTag = slugify(c);
          const isAINews = lowerCategories[idx] === 'ai news';
          const tagClass = isAINews ? 'post-tag ai-news-tag ai-gradient-tag' : 'post-tag';
          return <a class={tagClass} href={`/tags/${slugTag}/`}>{c}</a>;
        })}</div>}
      </header>
      <div class="post-body prose">
        <Content />
      </div>
      
      {/* Related Posts */}
      <RelatedPosts posts={relatedPosts} />
    </article>
  </div>
  <div class="back-link"><a href="/ai-news/">← Back to AI News</a></div>
</BaseLayout>

<style>
  .post-layout { display:grid; grid-template-columns: 260px 1fr; gap:2.5rem; }
  .sidebar-left { position:relative; }
  @media (max-width: 1080px) { .post-layout { grid-template-columns: 1fr; } }
</style>
