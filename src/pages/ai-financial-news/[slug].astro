---
import BaseLayout from "../../layouts/BaseLayout.astro";
import TableOfContents from '../../components/TableOfContents.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import RelatedPosts from '../../components/RelatedPosts.astro';
import TickerTimeline from '../../components/TickerTimeline.astro';
import StockChart from '../../components/StockChart.astro';
import UnpublishedWarning from '../../components/UnpublishedWarning.astro';
import { getAllAifinnews, getAllProcessedContent, findAifinnewsBySlug, getTickerTimeline } from '../../utils/dataCache';
import { RelatedPostsFinder, generateBreadcrumbs } from '../../utils/relatedContentOptimized';
import { slugify } from '../../utils/slugify';
import { isArticleNew } from '../../utils/newArticles';

export async function getStaticPaths() {
  const posts = await getAllAifinnews();
  return posts.map(post => ({ params: { slug: post.slug } }));
}

const { slug } = Astro.params;
const post = await findAifinnewsBySlug(slug!);
if (!post) throw new Error(`AI Financial News post not found for slug: ${slug}`);

// Get raw post for rendering
const aifinnews = await getAllAifinnews();
const rawPost = aifinnews.find(p => p.slug === slug);
if (!rawPost) throw new Error(`Raw AI financial news post not found for slug: ${slug}`);

// Use precomputed metadata
const stats = post.readingTime;
const excerpt = post.excerpt;
const canonical = post.urlPath;
const postImage = `https://earezki.com/assets/og-image-default.jpg`;
const postKeywords = 'Stock Weather AI, Financial Analysis, Stock Market';

// Precompute lowercase categories for runtime optimization
const lowerCategories = post.data.categories?.map((c: string) => c.toLowerCase()) || [];

// Check if article is new
const isNew = isArticleNew(post.slug, 'aifinnews');

// Generate breadcrumbs
const breadcrumbs = generateBreadcrumbs(canonical, post.data.title);

// Initialize optimized related posts finder with all content
const allContent = await getAllProcessedContent();
const relatedFinder = new RelatedPostsFinder(allContent);

// Find related content using optimized algorithm
const relatedPosts = relatedFinder.findRelated(post, 4);

// Get ticker timeline if ticker exists
const ticker = (post.data as any).ticker;
const tickerTimeline = ticker ? await getTickerTimeline(ticker) : [];

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: post.data.title,
  description: excerpt,
  image: postImage,
  datePublished: post.data.pubDate.toISOString(),
  dateModified: post.data.pubDate.toISOString(),
  author: {
    '@type': 'Person',
    name: 'El Mehdi Arezki',
    url: 'https://earezki.com/about',
    jobTitle: 'Lead Software Engineer',
    sameAs: [
      'https://github.com/earezki',
      'https://www.linkedin.com/in/mehdi-arezki'
    ]
  },
  publisher: {
    '@type': 'Organization',
    name: 'Dev|Journal',
    url: 'https://earezki.com',
    logo: {
      '@type': 'ImageObject',
      url: 'https://earezki.com/assets/logo.png'
    }
  },
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': 'https://earezki.com' + canonical
  }
};
const { Content } = await rawPost.render();
---
<BaseLayout 
  title={post.data.title} 
  description={excerpt} 
  keywords={postKeywords}
  canonical={canonical} 
  image={postImage}
  structuredData={structuredData}
  isArticlePage={true}>
  <Breadcrumbs breadcrumbs={breadcrumbs} isNew={isNew} />
  <div class="post-layout">
    <aside class="sidebar-left">
      <TableOfContents markdown={post.body} />
    </aside>
    <article class="post">
      <header class="post-header">
        <h1>{post.data.title}</h1>
        <div class="meta">
          <time datetime={post.data.pubDate.toISOString()}>{post.data.pubDate.toDateString()}</time>
          <span>• {stats.text}</span>
        </div>
        {post.data.categories && <div class="tag-row">{post.data.categories.map((c: string, idx: number) => {
          const slugTag = slugify(c);
          const isStockWeatherAI = lowerCategories[idx] === 'stock weather ai';
          const tagClass = isStockWeatherAI ? 'post-tag ai-news-tag ai-gradient-tag' : 'post-tag';
          return <a class={tagClass} href={`/tags/${slugTag}/`}>{c}</a>;
        })}<a class="post-tag performance-tag" href="/ai-financial-news/performance/">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"></polyline>
          </svg>
          Performance
        </a></div>}
      </header>
      
      <UnpublishedWarning pubDate={post.data.pubDate} />
      
      <div class="ai-assisted-banner">
        <p><strong>AI-Generated Financial Analysis:</strong> This article was created with AI assistance for educational purposes only. This is not financial advice. Always conduct your own research and consult with qualified financial advisors before making investment decisions.</p>
      </div>
      
      {ticker && (
        <StockChart 
          ticker={ticker} 
          articleDate={post.data.pubDate.toISOString().split('T')[0]} 
        />
      )}
      
      <div class="post-body prose">
        <Content />
      </div>
      
      {/* Ticker Timeline - shows all analyses for this ticker */}
      {ticker && tickerTimeline.length > 1 && (
        <TickerTimeline 
          ticker={ticker} 
          posts={tickerTimeline} 
          currentSlug={slug!} 
        />
      )}
      
      {/* Related Posts */}
      <RelatedPosts posts={relatedPosts} />
    </article>
  </div>
  <div class="back-link"><a href="/ai-financial-news/">← Back to AI Financial News</a></div>
</BaseLayout>

<script>
  // Runtime styling: detect Prediction: increase/decrease and apply color styling
  if (typeof window !== 'undefined') {
    document.addEventListener('DOMContentLoaded', () => {
      const postBody = document.querySelector('.post-body');
      if (!postBody) return;
      
      const paragraphs = postBody.querySelectorAll('p');
      paragraphs.forEach((p: Element) => {
        const text = (p.textContent || '').toLowerCase();
        
        // Check if this paragraph contains "Prediction:"
        if (text.includes('prediction:')) {
          // Determine if it's increase or decrease
          if (text.includes('increase')) {
            p.classList.add('prediction-increase');
          } else if (text.includes('decrease')) {
            p.classList.add('prediction-decrease');
          }
        }
      });
    });
  }
</script>

<style>
  .tag-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 1rem;
    align-items: center;
  }

  .performance-tag {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    margin-left: auto;
    background: linear-gradient(135deg, rgba(102, 126, 234, 0.1), rgba(118, 75, 162, 0.1));
    border: 1px solid rgba(102, 126, 234, 0.3);
    color: #667eea;
    font-weight: 600;
    font-size: 0.75rem;
    padding: 0.25rem 0.75rem;
    border-radius: var(--radius-sm);
    text-decoration: none;
    transition: all 0.2s;
  }

  .performance-tag:hover {
    background: linear-gradient(135deg, #667eea, #764ba2);
    color: white;
    border-color: transparent;
    transform: translateY(-1px);
  }

  html[data-theme="dark"] .performance-tag {
    background: linear-gradient(135deg, rgba(102, 126, 234, 0.15), rgba(118, 75, 162, 0.15));
    border-color: rgba(102, 126, 234, 0.4);
    color: #a5b4fc;
  }

  html[data-theme="dark"] .performance-tag:hover {
    background: linear-gradient(135deg, #667eea, #764ba2);
    color: white;
  }

  .post-layout { 
    display: grid; 
    grid-template-columns: 260px 1fr; 
    gap: 2.5rem;
    width: 100%;
    max-width: 100%;
    box-sizing: border-box;
  }
  .sidebar-left { 
    position: relative;
    min-width: 0;
    overflow: hidden;
  }
  
  @media (max-width: 1080px) { 
    .post-layout { 
      grid-template-columns: 1fr;
      width: 100%;
      max-width: 100%;
      padding: 0;
      margin: 0;
    }
  }
  @media (max-width: 768px) { 
    .post-layout { 
      display: block;
      width: 100%;
      max-width: 100%;
      padding: 0;
      margin: 0;
    }
    .sidebar-left {
      display: none;
    }
  }
</style>
