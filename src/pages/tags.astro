---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getAllTags, getProcessedAinews, getProcessedAifinnews } from '../utils/dataCache';
import { slugify } from '../utils/slugify';
import { isArticleNew } from '../utils/newArticles';

const tagMap = await getAllTags();

const tags = Array.from(tagMap.entries())
  .sort((a,b) => a[0].localeCompare(b[0]));
---
<BaseLayout title="Tags" description="Browse posts by category/tag">
  <h1>Tags</h1>
  <ul style="list-style: none; padding: 0; display: flex; flex-wrap: wrap; gap: 0.75rem;">
    {tags.map(([name, count]) => {
      const slugTag = slugify(name);
      const nameLower = name.toLowerCase();
      const isAINews = nameLower === 'ai news';
      const isStockWeatherAI = nameLower === 'stock weather ai';
      const tagClass = isAINews ? 'post-tag ai-news-tag ai-gradient-tag' : 
                       isStockWeatherAI ? 'post-tag stock-weather-ai-tag ai-gradient-tag' : 
                       'post-tag';
      return (
        <li><a class={tagClass} href={`/tags/${slugTag}/`}>{name} <span style="opacity:.6;">({count})</span></a></li>
      );
    })}
  </ul>
</BaseLayout>
