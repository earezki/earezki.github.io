---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getAllTags, getPostsByTag } from '../../utils/dataCache';

export async function getStaticPaths() {
  const tagMap = await getAllTags();
  
  return Array.from(tagMap.entries()).map(([label, count]) => {
    const slug = label.toLowerCase().replace(/\s+/g,'-');
    return { params: { tag: slug }, props: { slug, label, count } };
  });
}

const { slug, label, count } = Astro.props;
const allFiltered = await getPostsByTag(slug);
---
<BaseLayout title={`Tag: ${label}`}>
  <h1>Tag: {label}</h1>
  <p style="color: var(--color-text-alt); margin-bottom: 1.5rem;">{count} {count === 1 ? 'article' : 'articles'}</p>
  <ul style="list-style:none; padding:0;">
    {allFiltered.map(p => (
      <li style="margin:.6rem 0;">
        <a href={p.urlPath}>{p.data.title}</a>
        {p.collection === 'ainews' && <span class="post-tag ai-news-tag" style="margin-left: 0.5rem; font-size: 0.7rem;">AI News</span>}
      </li>
    ))}
  </ul>
  <p style="margin-top:2rem;"><a href="/tags/">← All tags</a></p>
</BaseLayout>
