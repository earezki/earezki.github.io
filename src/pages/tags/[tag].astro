---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getAllTags, getPostsByTag } from '../../utils/dataCache';
import { slugify } from '../../utils/slugify';

export async function getStaticPaths() {
  const tagMap = await getAllTags();
  
  // Build paths but skip any tags that slugify to an empty string
  const paths = [] as Array<any>;
  for (const [label, count] of Array.from(tagMap.entries())) {
    const slug = slugify(label);
    if (!slug) {
      // If a label produces an empty slug, skip it — this avoids "Missing parameter: tag"
      // Optional: uncomment the console.log for debugging during builds
      // console.warn('[tags] skipping empty slug for label:', JSON.stringify(label));
      continue;
    }
    paths.push({ params: { tag: slug }, props: { slug, label, count } });
  }

  return paths;
}

const { slug, label, count } = Astro.props;
const allFiltered = await getPostsByTag(slug);
---
<BaseLayout title={`Tag: ${label}`}>
  <h1>Tag: {label}</h1>
  <p style="color: var(--color-text-alt); margin-bottom: 1.5rem;">{count} {count === 1 ? 'article' : 'articles'}</p>
  <ul style="list-style:none; padding:0;">
    {allFiltered.map(p => (
      <li style="margin:.6rem 0;">
        <a href={p.urlPath}>{p.data.title}</a>
        {p.collection === 'ainews' && <span class="post-tag ai-news-tag ai-gradient-tag" style="margin-left: 0.5rem; font-size: 0.7rem;">AI News</span>}
        {p.collection === 'aifinnews' && <span class="post-tag stock-weather-ai-tag ai-gradient-tag" style="margin-left: 0.5rem; font-size: 0.7rem;">Stock Weather AI</span>}
      </li>
    ))}
  </ul>
  <p style="margin-top:2rem;"><a href="/tags/">← All tags</a></p>
</BaseLayout>
