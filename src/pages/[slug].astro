---
import BaseLayout from "../layouts/BaseLayout.astro";
import TableOfContents from '../components/TableOfContents.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import RelatedPosts from '../components/RelatedPosts.astro';
import SeriesNavigation from '../components/SeriesNavigation.astro';
import UnpublishedWarning from '../components/UnpublishedWarning.astro';
import { getAllPosts, getAllProcessedContent, findPostBySlug } from '../utils/dataCache';
import { RelatedPostsFinder, generateBreadcrumbs } from '../utils/relatedContentOptimized';
import { slugify } from '../utils/slugify';
import { isArticleNew } from '../utils/newArticles';

export async function getStaticPaths() {
  const posts = await getAllPosts();
  return posts.map(post => ({ params: { slug: post.slug } }));
}

const { slug } = Astro.params;
const post = await findPostBySlug(slug!);
if (!post) throw new Error(`Post not found for slug: ${slug}`);

const posts = await getAllPosts();
const rawPost = posts.find(p => p.slug === slug);
if (!rawPost) throw new Error(`Raw post not found for slug: ${slug}`);

const stats = post.readingTime;
const excerpt = post.excerpt;
const canonical = post.urlPath;
const postImage = `https://earezki.com/assets/og-image-default.jpg`;
const postKeywords = post.data.categories?.join(', ') || 'software architecture, backend development';

const lowerCategories = post.data.categories?.map((c: string) => c.toLowerCase()) || [];

const hasAIAssisted = lowerCategories.includes('ai assisted');

const isNew = isArticleNew(post.slug, 'posts');

const breadcrumbs = generateBreadcrumbs(canonical, post.data.title);

const allContent = await getAllProcessedContent();
const relatedFinder = new RelatedPostsFinder(allContent);

const relatedPosts = relatedFinder.findRelated(post, 4);
const series = relatedFinder.detectSeries(post);
const seriesPosts = series ? relatedFinder.findSeriesPosts(post) : [];

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: post.data.title,
  description: excerpt,
  image: postImage,
  datePublished: post.data.pubDate.toISOString(),
  dateModified: post.data.pubDate.toISOString(),
  author: {
    '@type': 'Person',
    name: 'El Mehdi Arezki',
    url: 'https://earezki.com/about',
    jobTitle: 'Lead Software Engineer',
    sameAs: [
      'https://github.com/earezki',
      'https://www.linkedin.com/in/mehdi-arezki'
    ]
  },
  publisher: {
    '@type': 'Organization',
    name: 'Dev|Journal',
    url: 'https://earezki.com',
    logo: {
      '@type': 'ImageObject',
      url: 'https://earezki.com/assets/logo.png'
    }
  },
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': 'https://earezki.com' + canonical
  }
};
const { Content } = await rawPost.render();
---
<BaseLayout 
  title={post.data.title} 
  description={excerpt} 
  keywords={postKeywords}
  canonical={canonical} 
  image={postImage}
  structuredData={structuredData}
  isArticlePage={true}>
  <Breadcrumbs breadcrumbs={breadcrumbs} isNew={isNew} />
  <div class="post-layout">
    <aside class="sidebar-left">
      <TableOfContents markdown={post.body} />
    </aside>
    <article class="post">
      <header class="post-header">
        <h1>{post.data.title}</h1>
        <div class="meta">
          <time datetime={post.data.pubDate.toISOString()}>{post.data.pubDate.toDateString()}</time>
          <span>• {stats.text}</span>
        </div>
        {post.data.categories && <div class="tag-row">{post.data.categories
          .filter((c: string, idx: number) => lowerCategories[idx] !== 'ai assisted')
          .map((c: string, idx: number) => {
          const slugTag = slugify(c);
          const categoryLower = c.toLowerCase();
          const isAINews = categoryLower === 'ai news';
          return <a class={`post-tag ${isAINews ? 'ai-news-tag' : ''}`} href={`/tags/${slugTag}/`}>{c}</a>;
        })}</div>}
      </header>
      <UnpublishedWarning pubDate={post.data.pubDate} />
      {hasAIAssisted && (
        <div class="ai-assisted-banner">
          <p><strong>Note:</strong> This article was refined and organized by AI, but the content and research are entirely human.</p>
        </div>
      )}
      <div class="post-body prose">
        <Content />
      </div>
      
      {/* Series Navigation - appears if post is part of a series */}
      {series && seriesPosts.length > 1 && (
        <SeriesNavigation series={series} posts={seriesPosts} currentSlug={slug!} />
      )}
      
      {/* Related Posts */}
      <RelatedPosts posts={relatedPosts} />
    </article>
  </div>
  <div class="back-link"><a href="/">← Back to home</a></div>
</BaseLayout>

<style>
  .post-layout { 
    display: grid; 
    grid-template-columns: 260px 1fr; 
    gap: 2.5rem;
    width: 100%;
    max-width: 100%;
    box-sizing: border-box;
  }
  .sidebar-left { 
    position: relative;
    min-width: 0;
    overflow: hidden;
  }
  @media (max-width: 1080px) { 
    .post-layout { 
      grid-template-columns: 1fr;
      width: 100%;
      max-width: 100%;
      padding: 0;
      margin: 0;
    }
  }
  @media (max-width: 768px) { 
    .post-layout { 
      display: block;
      width: 100%;
      max-width: 100%;
      padding: 0;
      margin: 0;
    }
    .sidebar-left {
      display: none;
    }
  }
</style>
